# ── Agent ────────────────────────────────────────────────────────────────────
GOOSE_PROVIDER=xai
GOOSE_MODEL=grok-4-1-fast-reasoning
GOOSE_HOST=0.0.0.0
GOOSE_PORT=3000
GOOSE_TLS=false

# ── MCP Server ───────────────────────────────────────────────────────────────
NEXUS_AUTH_TOKEN=
NEXUS_URL=http://mcp-server:8080
PORT=8080
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,mcp-server,gangus-agent

# ── Local LLM — Qwen3:8b (gangus-llm VM or docker --profile llm) ─────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── AI APIs (use Groq/DeepSeek/xAI — avoid Anthropic/OpenAI for cost) ────────
GROQ_API_KEY=
XAI_API_KEY=
XAI_HOST=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# ── Infrastructure ────────────────────────────────────────────────────────────
GITHUB_TOKEN=
DIGITALOCEAN_TOKEN=
RUNPOD_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Shell / SSH ───────────────────────────────────────────────────────────────
ALLOWED_SSH_HOSTS=localhost
