# ── Gangoos-coder environment template ───────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.
#
# SECURITY NOTES:
#   - NEXUS_AUTH_TOKEN must be set before accepting traffic.
#     Empty token → all protected routes return 503 (safe fail, not open access).
#   - CLOUDFLARE_ACCOUNT_ID and GITHUB_OWNER must be set explicitly.
#     No identifiers are hardcoded in the runtime defaults.
#   - Docker socket is NOT mounted by default.
#     Use docker-compose.privileged.yml (explicit opt-in) if shell/docker tools need it.
#
# TOPOLOGY MODES:
#   local   — all services on one machine:
#               docker compose --profile llm up
#             OLLAMA_HOST=http://ollama:11434 (docker network name)
#
#   remote  — 2-VM split (production):
#               VM1: gangus-agent + mcp-server
#               VM2: ollama + qwen3:8b
#               docker compose -f docker-compose.remote.yml up
#             OLLAMA_HOST=http://<vm2-private-ip>:11434
#             Fallback: GROQ_API_KEY → DEEPSEEK_API_KEY if VM2 unreachable
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Agent ─────────────────────────────────────────────────────────────────────
GOOSE_PROVIDER=xai
GOOSE_MODEL=grok-4-1-fast-reasoning
GOOSE_HOST=0.0.0.0
GOOSE_PORT=3000
GOOSE_TLS=false

# ── MCP Server ────────────────────────────────────────────────────────────────
# REQUIRED: set a strong random token. Empty → 503 on all protected routes.
NEXUS_AUTH_TOKEN=
NEXUS_URL=http://mcp-server:8080
PORT=8080
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,mcp-server,gangus-agent

# ── Local LLM — Qwen3:8b ──────────────────────────────────────────────────────
# Canonical env var: OLLAMA_HOST (URL), OLLAMA_MODEL (model name)
# LOCAL topology:  OLLAMA_HOST=http://ollama:11434   (docker compose --profile llm)
# REMOTE topology: OLLAMA_HOST=http://<vm2-ip>:11434  (docker-compose.remote.yml)
# No hardcoded IPs. Set via env only.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── Fallback LLM providers (used when OLLAMA_HOST is unreachable) ─────────────
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
XAI_HOST=

# ── Other AI APIs ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
MISTRAL_API_KEY=

# ── Mojo code execution ───────────────────────────────────────────────────────
# disabled  — default; returns clear error (Mojo SDK not installed)
# subprocess — set when Mojo SDK binary is in PATH
MOJO_EXEC_BACKEND=disabled
MOJO_BINARY=mojo
MOJO_EXEC_TIMEOUT=30

# ── GitHub ────────────────────────────────────────────────────────────────────
# REQUIRED for GitHub tools. No default owner hardcoded — must be set explicitly.
GITHUB_TOKEN=
GITHUB_OWNER=

# ── Cloudflare ────────────────────────────────────────────────────────────────
# REQUIRED for Cloudflare tools. No default account ID hardcoded.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ── Infrastructure ─────────────────────────────────────────────────────────────
DIGITALOCEAN_TOKEN=
RUNPOD_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Cloud providers ────────────────────────────────────────────────────────────
VERCEL_TOKEN=
RENDER_API_KEY=
FLY_API_TOKEN=

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated allowlist for SSH targets. Must not be empty or contain '*'.
ALLOWED_SSH_HOSTS=localhost
